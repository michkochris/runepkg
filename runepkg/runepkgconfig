# file description: runepkg config settings

# make sure to not to leave ending / forward slash!
# and use full linux path names ie. or ~/ for user home directory...

# main config file (system-wide installed at /etc/runepkg/runepkgconfig)

# main directory where runepkg does work, can change for optional alternate install location of packages...
# just change all appropriate values...runepkg_dir, control_dir, install_dir, runepkg_db, download_dir...
runepkg_dir=~/runepkg_dir

# directory where runepkg unpacks .deb pkg info
# where runepkg processes .deb control files  
control_dir=~/runepkg_dir/control_dir

# main directory where runepkg installs programs
# normally / unless testing and development... change if needed...
#install_dir=/
install_dir=~/runepkg_dir/install_dir

# directory where runepkg stores its persistent package database
# a subdirectory for each installed package and a binary Pkginfo file inside
runepkg_db=~/runepkg_dir/runepkg_db

# main runepkg download directory for downloading .deb's from debian repo..
download_dir=~/runepkg_dir/download_dir

# Delete per-package extraction trees under control_dir after install (yes/no, default yes).
# Set to no to keep unpacked control/data directories for debugging.
cleanup=yes

# runepkg debian style sources.list info here
# You can use any Debian-based repository (Debian, Ubuntu, Kali, Debian archives, etc.).
#
# IMPORTANT: It is highly recommended to use ONLY ONE distribution ecosystem
# at a time (e.g., just Kali, or just Debian Stable). While runepkg can aggregate
# metadata from multiple sources, the current URL resolver prefers the first
# base URL defined. Mixing repositories with different base URLs may cause
# download failures (404) if a package exists in one but not the other.

# Debian Stable (Bookworm) - Example of multiple sources sharing the SAME base URL
# (This is safe because all metadata will point to the same server)
# deb http://deb.debian.org/debian bookworm main contrib non-free non-free-firmware
# deb http://deb.debian.org/debian bookworm-updates main contrib non-free non-free-firmware
# deb http://deb.debian.org/debian bookworm-backports main contrib non-free non-free-firmware
# deb-src http://deb.debian.org/debian bookworm main contrib non-free non-free-firmware

# runepkg and runar linux use kali rolling latest release style packages by default.
# Kali Linux (Optional/Rolling)
# See: https://www.kali.org/docs/general-use/kali-linux-sources-list-repositories/
deb http://http.kali.org/kali kali-rolling main contrib non-free non-free-firmware
deb-src http://http.kali.org/kali kali-rolling main contrib non-free non-free-firmware

